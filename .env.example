# Everything here is optional — Trailin is configured in the app, and an empty
# (or absent) .env runs with the defaults shown below.
#
# LLM provider sign-in (Claude, OpenAI, GitHub Copilot, …) and the model the
# agent uses are set under Settings. Pipedream credentials for Gmail/Outlook
# are entered under Settings -> Connect email; the env vars below are only a
# fallback (values saved in the app take precedence).

# --- Server (optional; defaults shown) ---
# Interface the API binds to. Loopback by default — the API has no auth, so it
# must not be reachable from the LAN. Set 0.0.0.0 to expose it deliberately
# (a container, or a host you trust).
HOST=127.0.0.1
PORT=3001
DATABASE_PATH=./data/trailin.db
# Default drop folder for the document library (./data/library). Only the
# starting value — the folder can be changed in the app (Knowledge page),
# and a folder chosen there takes precedence.
LIBRARY_PATH=./data/library

# --- Logging ---
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Set a path to also tee logs to a rotating file (daily / 10MB, 14 kept);
# unset = stdout only.
# LOG_FILE=./data/logs/trailin.log

# --- Agent ---
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-opus-4-8
# Abort a single automation run after this many ms (default 5 minutes), so a
# stuck model or MCP call can't wedge the schedule.
AUTOMATION_RUN_TIMEOUT_MS=300000

# --- Demo mode ---
# TRAILIN_DEMO=1 runs a seeded in-memory sandbox: no scheduler, no Pipedream,
# and a separate ./data/demo.db so it never touches real data.
# TRAILIN_DEMO=1

# --- Mailbox mirror (email/sync) ---
SYNC_INTERVAL_MS=180000
SYNC_BACKFILL_DAYS=30
SYNC_PAGE_SIZE=50

# --- Thread enrichment (email/enrich) ---
# ENRICH_MODEL=            # cheap-tier model id; blank = built-in candidates
ENRICH_BATCH=20
ENRICH_CONCURRENCY=2

# --- Pipedream Connect (fallback; the app's Settings form is the normal path) ---
# OAuth client: https://pipedream.com/settings/api  ·  project: https://pipedream.com/projects
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=proj_...
PIPEDREAM_ENVIRONMENT=development

# Stable id for "you" inside Pipedream Connect. Any string; keep it constant.
PIPEDREAM_EXTERNAL_USER_ID=local-user
